{
  "model": {
    "vocab_size": 1024,
    "context_length": 128,
    "n_embed": 128,
    "n_head": 4,
    "n_kv_head": 2,
    "n_blocks": 4,
    "mlp_ratio": 2.6666666666666665,
    "rope_theta": 10000.0,
    "tie_weights": true,
    "naive_attention": false
  },
  "train": {
    "data_dir": "data",
    "out_dir": "checkpoints",
    "batch_size": 16,
    "grad_accum": 1,
    "steps": 600,
    "lr": 0.0003,
    "min_lr": 3e-05,
    "warmup_steps": 50,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "eval_every": 200,
    "eval_iters": 50,
    "save_every": 0,
    "keep_last": 3,
    "seed": 1337,
    "device": null,
    "compile": false
  }
}