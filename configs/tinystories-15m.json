{
  "model": {
    "vocab_size": 8256,
    "context_length": 256,
    "n_embed": 384,
    "n_head": 6,
    "n_kv_head": 6,
    "n_blocks": 8,
    "mlp_ratio": 2.6666666666666665,
    "rope_theta": 10000.0,
    "tie_weights": true,
    "naive_attention": false
  },
  "train": {
    "data_dir": "data",
    "out_dir": "checkpoints",
    "batch_size": 32,
    "grad_accum": 1,
    "steps": 3700,
    "lr": 0.0006,
    "min_lr": 6e-05,
    "warmup_steps": 200,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "eval_every": 500,
    "eval_iters": 50,
    "save_every": 500,
    "keep_last": 2,
    "seed": 1337,
    "device": null,
    "compile": false
  }
}
