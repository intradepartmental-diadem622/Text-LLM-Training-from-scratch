{
  "model": {
    "vocab_size": 8256,
    "context_length": 512,
    "n_embed": 768,
    "n_head": 12,
    "n_kv_head": 4,
    "n_blocks": 12,
    "mlp_ratio": 2.6666666666666665,
    "rope_theta": 10000.0,
    "tie_weights": true,
    "naive_attention": false
  },
  "train": {
    "data_dir": "data",
    "out_dir": "checkpoints",
    "batch_size": 32,
    "grad_accum": 4,
    "steps": 100000,
    "lr": 0.0003,
    "min_lr": 3e-05,
    "warmup_steps": 1000,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "eval_every": 1000,
    "eval_iters": 100,
    "save_every": 5000,
    "keep_last": 3,
    "seed": 1337,
    "device": null,
    "compile": false
  }
}